# Server
PORT=3001                          # Port the Express server listens on
NODE_ENV=development               # Runtime environment: development | production | test

# Database
DATABASE_PATH=./data/spur_chat.db  # Path to the SQLite file; parent dir is created automatically

# Gemini (Google AI)
# Get a free API key (no credit card required) at https://aistudio.google.com -> "Get API key"
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash      # Model to use for chat responses

# LLM behaviour
LLM_MAX_TOKENS=400                 # Maximum tokens in a single LLM response
LLM_TIMEOUT_MS=15000               # Milliseconds before an LLM request is aborted

# Guardrails
MAX_MESSAGE_LENGTH=2000            # Maximum characters accepted in a user message
MAX_HISTORY_MESSAGES=20            # How many past messages to send as context to the LLM

# CORS
CORS_ORIGINS=http://localhost:5173 # Comma-separated list of allowed origins, e.g.:
                                   # http://localhost:5173,https://yourapp.vercel.app
